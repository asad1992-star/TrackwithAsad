{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string", "description": "Preferred currency symbol (e.g., $, Rs, £)" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or Expense entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "walletId": { "type": "string" },
        "notes": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "recurringPeriod": { "type": "string", "enum": ["monthly", "weekly", "yearly"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "date"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget limit for a category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "limit": { "type": "number" },
        "month": { "type": "string", "description": "Month in YYYY-MM format" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "limit", "month"]
    },
    "Goal": {
      "title": "Saving Goal",
      "description": "A goal to save towards",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "targetAmount", "currentAmount"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "A payment source or storage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["cash", "bank", "easypaisa", "jazzcash", "other"] },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "balance"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Recurring service subscription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "billingCycle": { "type": "string", "enum": ["monthly", "yearly"] },
        "nextBillingDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "amount", "billingCycle"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transaction history"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User monthly budgets"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User saving goals"
    },
    "/users/{userId}/wallets/{walletId}": {
      "schema": "Wallet",
      "description": "User wallets/accounts"
    },
    "/users/{userId}/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User subscriptions"
    }
  }
}
